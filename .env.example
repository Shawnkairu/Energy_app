# e.mappa environment variables — copy to .env and fill in.
# All backend keys are prefixed EMAPPA_ (read by app.config.Settings).

# ============================================================================
# Backend
# ============================================================================
EMAPPA_DATABASE_URL=postgresql+asyncpg://emappa:emappa@localhost:5432/emappa
EMAPPA_JWT_SECRET=replace-with-32-byte-hex
EMAPPA_JWT_TTL_HOURS=24

# Email OTP via Resend (https://resend.com)
EMAPPA_RESEND_API_KEY=
EMAPPA_RESEND_FROM=auth@emappa.test
EMAPPA_ALLOW_DEV_OTP_CONSOLE=true

# Admin allowlist — comma-separated. Only emails on this list may be granted admin
# via backend/scripts/grant_admin.py. POST /me/onboarding-complete refuses role='admin'.
EMAPPA_ADMIN_EMAILS=admin@emappa.test

# Solar data adapters (free public APIs; DEMO_KEY works for low volumes)
EMAPPA_NREL_PVWATTS_BASE=https://developer.nrel.gov/api/pvwatts/v8.json
EMAPPA_NREL_API_KEY=DEMO_KEY
EMAPPA_NASA_POWER_BASE=https://power.larc.nasa.gov/api/temporal/hourly/point
EMAPPA_OPEN_METEO_BASE=https://api.open-meteo.com/v1/forecast

# Roof footprint
EMAPPA_MS_FOOTPRINTS_BASE=https://minedbuildings.z5.web.core.windows.net
EMAPPA_GOOGLE_MAPS_STATIC_KEY=

# Dev seed (loads pilot fixtures on startup)
EMAPPA_DEV_SEED=false

# ============================================================================
# Frontends
# ============================================================================

# Mobile (Expo): public env vars must be EXPO_PUBLIC_*
EXPO_PUBLIC_API_BASE_URL=http://localhost:8010

# Cockpit & Website (Vite): public env vars must be VITE_*
VITE_API_BASE_URL=http://localhost:8010
VITE_GOOGLE_MAPS_KEY=
VITE_MAPBOX_TOKEN=
