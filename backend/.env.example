# Copy to .env locally. Loaded by pydantic-settings with prefix EMAPPA_ (see app/config.py).
# In docker-compose, use EMAPPA_* environment variables directly.

EMAPPA_DATABASE_URL=postgresql+asyncpg://emappa:emappa@localhost:5432/emappa
EMAPPA_JWT_SECRET=change-me-in-production
EMAPPA_JWT_TTL_HOURS=24

EMAPPA_RESEND_API_KEY=
EMAPPA_RESEND_FROM=auth@emappa.test
EMAPPA_ALLOW_DEV_OTP_CONSOLE=true
EMAPPA_ADMIN_EMAILS=admin@emappa.test

EMAPPA_NREL_API_KEY=DEMO_KEY
EMAPPA_DEV_SEED=false
