# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production / Vite
/build
/dist
/.vite
/standalone-dist
/e-mappa-standalone.html

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editor / tooling (not part of the shipped site)
/.claude

# design research / exports (not the app)
/design-extract-output

# ad-hoc share bundles (use npm run build:standalone instead)
/share-package/
/share-package 2/
/emappa-share*.html
/emappa-share-package.zip

# local vendor tools
/vendor/design-extract
